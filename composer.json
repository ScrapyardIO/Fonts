{
    "name": "scrapyard-io/fonts",
    "description": "The ScrapyardIO Extended Fonts package.",
    "license": "MIT",
    "homepage": "https://scrapyard-io.projectsaturnstudios.com",
    "version": "0.5.0",
    "support": {
        "issues": "https://github.com/scrapyard-io/framework/issues",
        "source": "https://github.com/scrapyard-io/framework"
    },
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "bare-metal/gfx": "^0.5.0"
    },
    "require-dev": {
        "pestphp/pest": "^4",
        "scrapyard-io/framework": "^0.5.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../framework",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "BareMetal\\Fonts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.5.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev"
}
